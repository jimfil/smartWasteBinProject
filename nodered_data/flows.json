    {
        "id": "94d978749d9f1a82",
        "type": "function",
        "z": "2a0efe051790fb49",
        "name": "Deduplicate Alerts",
        "func": "let p = msg.payload;\n\nif (typeof p === \"string\") {\n    try { p = JSON.parse(p); } catch (e) { return null; }\n}\n\nif (!p || typeof p !== \"object\") return null;\n\nlet currentLevel = (p.level || \"\").toUpperCase();\nlet ts = p.timestamp || new Date().toISOString();\n\nif (currentLevel !== \"HIGH\" && currentLevel !== \"CRITICAL\") {\n    return null;\n}\n\nlet now = Date.now();\nlet last = flow.get(\"last_alert_time_by_level\") || {};\nlet cooldownMs = 6000; // 15 sec, change if you want\n\nif (last[currentLevel] && (now - last[currentLevel]) < cooldownMs) {\n    return null;\n}\n\nlast[currentLevel] = now;\nflow.set(\"last_alert_time_by_level\", last);\n\nmsg.payload = {\n    bin_id: p.bin_id || \"bin-01\",\n    level: currentLevel,\n    fill_pct: Number(p.fill_pct ?? p.fill_level ?? 0),\n    weight_g: Number(p.weight_g ?? p.weight ?? 0),\n    timestamp: ts\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 180,
        "wires": [
            [
                "65074a483a3c3dce"
            ]
        ]
    },

        "func": "let p = msg.payload;\n\nmsg.payload = {\n    bin_id: p.bin_id || \"bin-01\",\n    level: \"HIGH\",\n    fill_pct: Number(p.fill_pct ?? 0),\n    weight_g: Number(p.weight_g ?? 0),\n    timestamp: p.timestamp || new Date().toISOString(),\n    message: `WARNING - Bin ${p.bin_id || \"bin-01\"} is ${Number(p.fill_pct ?? 0)}% full. Schedule collection soon.`\n};\n\nflow.set(\"latestAlert\", { bin_id: msg.payload.bin_id || \"bin-01\", level: msg.payload.level || \"CRITICAL\" });\n\nreturn msg;",

    },
    {
        "id": "f00000000000000c",
        "type": "tab",
        "label": "Flow C: Alert Engine",
        "disabled": false,
        "info": "Routes warning levels. Branches to a Critical Alert flow (alerts/critical, dashboard popups, webhook) or a High Warning flow."
    },
    {
        "id": "f00000000000000d",
        "type": "tab",
        "label": "Flow D: Data Router & Archiver",
        "disabled": false,

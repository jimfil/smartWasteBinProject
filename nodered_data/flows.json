    "id": "func_dedup_alerts",
    "type": "function",
    "z": "f00000000000000c",
    "name": "Deduplicate Alerts",
    "func": "let currentLevel = msg.payload.level;\nlet lastAlertLevel = flow.get('last_alert_level') || '';\n\nif (currentLevel === 'HIGH' || currentLevel === 'CRITICAL') {\n    if (lastAlertLevel === currentLevel) {\n        return null;\n    }\n    flow.set('last_alert_level', currentLevel);\n    return msg;\n}\n\nflow.set('last_alert_level', currentLevel);\nreturn null;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 530,
    "y": 180,

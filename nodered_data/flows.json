        "id": "9bb0e650ee9d97d4",
        "type": "function",
        "z": "69d6bc9e21260366",
        "name": "Uptime Counter",
        "func": "let uptime = flow.get('uptime_seconds') || 0;\nuptime++;\nflow.set('uptime_seconds', uptime);\nlet sec = uptime % 60;\nlet min = Math.floor(uptime / 60) % 60;\nlet hrs = Math.floor(uptime / 3600) % 24;\nlet days = Math.floor(uptime / 86400);\nlet uptime_str = '';\nif (days > 0) uptime_str += days + 'd ';\nuptime_str += (hrs < 10 ? '0' : '') + hrs + ':' + (min < 10 ? '0' : '') + min + ':' + (sec < 10 ? '0' : '') + sec;\nmsg.payload = uptime_str;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,

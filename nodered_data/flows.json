        "id": "json_stringify_b",
        "type": "json",
        "z": "f00000000000000b",
        "name": "Stringify JSON",
        "property": "payload",
        "action": "str",
        "pretty": false,
        "x": 580,
        "y": 180,
        "wires": [
            [
                "mqtt_out_b_intensity",
                "widget_text_usage"
            ]
        ]
    },

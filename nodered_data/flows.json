  {
    "id": "func_replicate_intensity",
    "type": "function",
    "z": "f00000000000000b",
    "name": "Usage Intensity Rules",
    "func": "let fill_level = flow.get('fill_level') || 0;\nlet weight = flow.get('weight') || 0;\nlet now = Date.now();\n\nif (msg.topic === 'smartbin/sensor/weight') {\n    weight = parseFloat(msg.payload);\n    if (isNaN(weight)) weight = 0;\n    flow.set('weight', weight);\n    return null;\n}\n\nif (msg.topic !== 'smartbin/sensor/fill_level') {\n    return null;\n}\n\nfill_level = parseFloat(msg.payload);\nif (isNaN(fill_level)) fill_level = 0;\nflow.set('fill_level', fill_level);\n\nlet level = 'LOW';\nif (fill_level < 25) {\n    level = 'LOW';\n} else if (fill_level < 50) {\n    level = 'MEDIUM';\n} else if (fill_level <= 75) {\n    level = 'HIGH';\n} else {\n    level = 'CRITICAL';\n}\n\nmsg.payload = {\n    level: level,\n    fill_pct: fill_level,\n    weight_g: weight,\n    timestamp: new Date(now).toISOString()\n};\n\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 380,
    "y": 180,
    "wires": [
      [
        "widget_text_usage",
        "json_stringify_b"
      ]
    ]
  },

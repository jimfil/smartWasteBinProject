    {
        "id": "62efd5b4dc5fba35",
        "type": "function",
        "z": "c2309bf37c573735",
        "name": "Circular Event Buffer",
        "func": "let topic = msg.topic || '';\nif (topic.startsWith('smartbin/nodered/')) { \n    return null; \n}\n\nlet buffer = flow.get('event_buffer') || { virtual: [], sensor: [], alerts: [] };\n\nlet category = 'sensor';\nif (topic.includes('virtual')) category = 'virtual';\nelse if (topic.includes('alerts')) category = 'alerts';\n\nlet record = {\n    topic: topic,\n    payload: msg.payload,\n    timestamp: new Date().toISOString()\n};\n\nbuffer[category].push(record);\nif (buffer[category].length > 100) buffer[category].shift();\n\nflow.set('event_buffer', buffer);\n\n// Alert display formatting\nif (category === \"alerts\") {\n    let html = '<div style=\"font-family: monospace; font-size: 0.9em; max-height: 180px; overflow-y: auto; padding-right: 6px;\">';\n    let start = Math.max(0, buffer.alerts.length - 10);\n    \n    for (let i = buffer.alerts.length - 1; i >= start; i--) {\n        let item = buffer.alerts[i];\n        let parsed = item.payload;\n        \n        if (typeof parsed === \"string\") {\n            try { parsed = JSON.parse(parsed); } catch(e) {}\n        }\n        \n        let timeStr = new Date(item.timestamp).toLocaleTimeString();\n        \n        if (parsed && typeof parsed === \"object\") {\n            let level = parsed.level || \"INFO\";\n            let binId = parsed.binid || \"bin-01\";\n            let fill = parsed.fillpct ?? \"?\";\n            let message = parsed.message || \"\";\n            \n            let color = level === \"CRITICAL\" ? \"#f38ba8\" : \"#f9e2af\";\n            \n            html += `\n                <div style=\"padding: 8px; margin-bottom: 8px; background-color: #1e1e2e; border-left: 3px solid ${color}; border-radius: 4px;\">\n                    <div style=\"color: #cdd6f4;\">\n                        <span style=\"color: #89b4fa; font-weight: bold;\">${timeStr}</span> | \n                        <span style=\"color: ${color}; font-weight: bold;\">${level}</span>\n                    </div>\n                    <div style=\"color: #a6adc8; margin-top: 4px; font-size: 0.85em;\">${message}</div>\n                </div>\n            `;\n        } else {\n            html += `<div style=\"padding: 8px; color: #a6adc8;\">- ${timeStr} ${String(parsed)}</div>`;\n        }\n    }\n    \n    html += '</div>';\n    \n    if (buffer.alerts.length === 0) {\n        html = '<div style=\"color: #a6adc8; padding: 8px;\">- No alerts logged yet</div>';\n    }\n    \n    node.send([null, { payload: html }]);\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 320,
        "wires": [
            [],
            [
                "55c80067c0e369d3"
            ]
        ]

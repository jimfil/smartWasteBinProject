    {
        "id": "func_replicate_intensity",
        "type": "function",
        "z": "f00000000000000b",
        "name": "Usage Intensity Rules",
        "func": "let events = flow.get(\"events\") || [];\nlet fill_level = flow.get(\"fill_level\") || 0;\nlet weight = flow.get(\"weight\") || 0;\n\nlet now = Date.now();\nlet windowSize = 5 * 60 * 1000; // 5 minute window\n\nevents = events.filter(t => (now - t) < windowSize);\n\nif (msg.topic === \"smartbin/sensor/fill_level\") {\n    fill_level = parseFloat(msg.payload);\n    flow.set(\"fill_level\", fill_level);\n    events.push(now);\n} else if (msg.topic === \"smartbin/sensor/weight\") {\n    weight = parseFloat(msg.payload);\n    flow.set(\"weight\", weight);\n    events.push(now);\n}\n\nflow.set(\"events\", events);\n\nlet level = \"LOW\";\nif (fill_level < 25) {\n    level = \"LOW\";\n} else if (fill_level >= 25 && fill_level < 50) {\n    level = \"MEDIUM\";\n} else if (fill_level >= 50 && fill_level <= 75) {\n    level = \"HIGH\";\n} else if (fill_level > 75) {\n    level = \"CRITICAL\";\n}\n\nmsg.payload = {\n    \"level\": level,\n    \"fill_pct\": fill_level,\n    \"weight_g\": weight,\n    \"event_count\": events.length,\n    \"timestamp\": new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "x": 360,
        "y": 180,
        "wires": [
            [
                "json_stringify_b"
            ]
        ]
    },

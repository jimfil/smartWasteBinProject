        "id": "func_trigger_alert_counter",
        "type": "function",
        "z": "f00000000000000d",
        "name": "Increment Alert Counter",
        "func": "let count = flow.get(\"alert_count\") || 0;\ncount++;\nflow.set(\"alert_count\", count);\nmsg.payload = count;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "x": 630,
        "y": 260,
        "wires": [

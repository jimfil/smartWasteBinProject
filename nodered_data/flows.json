        "type": "function",
        "z": "f00000000000000f",
        "name": "Update Last Seen",
        "func": "let lastSeenMap = flow.get(\"last_seen_map\") || {};\nlet topic = msg.topic;\nlastSeenMap[topic] = new Date().toLocaleTimeString();\nflow.set(\"last_seen_map\", lastSeenMap);\n\nlet outStr = \"\";\nlet keys = Object.keys(lastSeenMap).sort();\nfor (let k of keys) {\n    outStr += \"* **\" + k + \"**: \" + lastSeenMap[k] + \"\\n\";\n}\n\nmsg.payload = outStr || \"No topics active yet\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "x": 350,
        "y": 540,
        "wires": [

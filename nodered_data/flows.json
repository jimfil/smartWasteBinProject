  {
    "id": "func_circular_buffer",
    "type": "function",
    "z": "f00000000000000d",
    "name": "Circular Event Buffer",
    "func": "let topic = msg.topic || '';\nif (topic.startsWith('smartbin/nodered/')) { return null; }\nlet buffer = flow.get('event_buffer') || { virtual: [], sensor: [], alerts: [] };\nlet category = 'sensor';\nif (topic.includes('virtual')) category = 'virtual';\nelse if (topic.includes('alerts')) category = 'alerts';\nlet record = { topic: topic, payload: msg.payload, timestamp: new Date().toISOString() };\nbuffer[category].push(record);\nif (buffer[category].length > 100) buffer[category].shift();\nflow.set('event_buffer', buffer);\nif (category === 'alerts') {\n  let listStr = '';\n  for (let i = buffer.alerts.length - 1; i >= Math.max(0, buffer.alerts.length - 10); i--) {\n    let item = buffer.alerts[i];\n    let parsed = item.payload;\n    if (typeof parsed === 'string') { try { parsed = JSON.parse(parsed); } catch(e) {} }\n    let msgText = typeof parsed === 'object' ? (parsed.message || JSON.stringify(parsed)) : parsed;\n    listStr += '* **' + new Date(item.timestamp).toLocaleTimeString() + '**: ' + msgText + '\\n';\n  }\n  node.send([null, { payload: listStr || '*No alerts logged yet*' }]);\n}\nreturn null;",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 370,
    "y": 320,
    "wires": [

    {
        "id": "func_circular_buffer",
        "type": "function",
        "z": "f00000000000000d",
        "name": "Circular Event Buffer",
        "func": "let buffer = flow.get(\"event_buffer\") || { \"virtual\": [], \"sensor\": [], \"alerts\": [] };\nlet topic = msg.topic;\nlet category = \"sensor\";\n\nif (topic.includes(\"virtual\")) {\n    category = \"virtual\";\n} else if (topic.includes(\"alerts\") || topic.includes(\"nodered/alert_log\")) {\n    category = \"alerts\";\n}\n\nlet record = {\n    \"topic\": topic,\n    \"payload\": msg.payload,\n    \"timestamp\": new Date().toISOString()\n};\n\nbuffer[category].push(record);\nif (buffer[category].length > 100) {\n    buffer[category].shift();\n}\n\nflow.set(\"event_buffer\", buffer);\n\n// Update alert list representation on dashboard\nif (category === \"alerts\") {\n    let listStr = \"\";\n    for(let i = buffer.alerts.length - 1; i >= Math.max(0, buffer.alerts.length - 10); i--){\n        let item = buffer.alerts[i];\n        let parsed = item.payload;\n        if (typeof parsed === 'string') {\n            try { parsed = json.loads(parsed); } catch(e) {}\n        }\n        let msgText = typeof parsed === 'object' ? (parsed.message || JSON.stringify(parsed)) : parsed;\n        listStr += \"* **\" + new Date(item.timestamp).toLocaleTimeString() + \"**: \" + msgText + \"\\n\";\n    }\n    let outMsg = { payload: listStr || \"*No alerts logged yet*\" };\n    node.send([null, outMsg]);\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "x": 370,
        "y": 320,
        "wires": [
            [],
            [
                "widget_text_alert_history"
            ]
        ]
    },

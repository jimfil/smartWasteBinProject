[
  {
    "id": "f00000000000000a",
    "type": "tab",
    "label": "Flow A: Raw Sensor Monitor",
    "disabled": false,
    "info": "Subscribes to raw fill level, weight, and motion sensors, attaches timestamps, and forwards to debug and live dashboard gauges."
  },
  {
    "id": "f00000000000000b",
    "type": "tab",
    "label": "Flow B: Usage Intensity Replication",
    "disabled": false,
    "info": "Replicates rule-based usage intensity level using fill updates only, while caching latest weight. Publishes structured JSON and updates dashboard cleanly."
  },
  {
    "id": "f00000000000000c",
    "type": "tab",
    "label": "Flow C: Alert Engine",
    "disabled": false,
    "info": "Routes warning levels and deduplicates HIGH/CRITICAL alerts so one state transition creates one alert."
  },
  {
    "id": "f00000000000000d",
    "type": "tab",
    "label": "Flow D: Data Router & Archiver",
    "disabled": false,
    "info": "Filters and logs all smartbin topics. Appends to a 100-event circular buffer and exposes it over GET /nodered/api/recent-events."
  },
  {
    "id": "f00000000000000e",
    "type": "tab",
    "label": "Flow E: ML Prediction Listener",
    "disabled": false,
    "info": "Listens to ML prediction, renders HTML badge cards, and pushes to Dashboard cards and smartbin/nodered/ml_display."
  },
  {
    "id": "f00000000000000f",
    "type": "tab",
    "label": "Flow F: Operator Dashboard & System Services",
    "disabled": false,
    "info": "Consolidates all UI widgets and runs background processes like the Node-RED heartbeat and system uptime counters."
  },
